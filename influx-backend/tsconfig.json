{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["server.ts", "src/**/*"],
  "exclude": ["node_modules"]
}
